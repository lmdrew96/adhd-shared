{
  "name": "adhd-shared",
  "private": true,
  "version": "0.0.0",
  "description": "ADHDesigns shared packages — UI themes, MCP kit, Clerk helpers.",
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "ui:publish": "pnpm --filter @adhdesigns/ui publish",
    "mcp-kit:publish": "pnpm --filter @adhdesigns/mcp-kit publish",
    "clerk:publish": "pnpm --filter @adhdesigns/clerk publish"
  }
}
